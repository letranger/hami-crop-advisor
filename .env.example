# 複製成 .env 後填入，或直接在 Vercel 後台的 Environment Variables 設定。
# .env 已被 .gitignore 排除，不會進版控。金鑰只放伺服器端，切勿寫進前端。

# RAG（依手冊回答）用兩把（都免費）：
#   GEMINI_API_KEY — 嵌入/檢索（aistudio.google.com/api-keys）
#   GROQ_API_KEY   — 產生回答（console.groq.com/keys）
GEMINI_API_KEY=
GROQ_API_KEY=

# 「上網查最新資訊」模式（選用）：Tavily 搜尋 API（tavily.com，免費、免綁卡）
# 沒設也不影響「依手冊回答」；只有按「上網查」才會用到。
TAVILY_API_KEY=

# 備用：若日後改用 Claude 生成才需要
ANTHROPIC_API_KEY=

# 共享診斷記錄 + 問題快取（選用）：Upstash Redis（Vercel 市集一鍵開通、免費）
# 在 Vercel 後台 Storage → 建立 Upstash Redis → 連結專案，會自動注入下列變數。
# 沒設也不影響：診斷記錄自動退回單機 localStorage，問答則每次即時查詢（不快取）。
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# （若用 Vercel KV 舊命名，程式亦相容 KV_REST_API_URL / KV_REST_API_TOKEN）
